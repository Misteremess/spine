# Copia a .env.production en el VPS (junto a docker-compose.production.yml).
# NUNCA se commitea (cubierto por .gitignore vía .env.*).

# Postgres — genera la contraseña con `openssl rand -hex 24` (NUNCA base64:
# un "+"/"/"/"=" en la password rompe el parseo de DATABASE_URL).
POSTGRES_USER=spine
POSTGRES_PASSWORD=
POSTGRES_DB=spine

# Debe apuntar al servicio "postgres" de la red interna de docker-compose,
# con las mismas credenciales que las tres variables de arriba.
DATABASE_URL=postgres://spine:CONTRASEÑA_GENERADA@postgres:5432/spine

# openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://api-spine.hyperfocus.es
WEB_ORIGIN=https://spine.hyperfocus.es

PORT=3123

# Fuentes de metadatos (coste cero salvo decisión expresa, ver docs/PLAN-PRODUCTO.md)
GOOGLE_BOOKS_API_KEY=
ISBNDB_KEY=
HARDCOVER_TOKEN=

# SMTP (Brevo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Spine <no-reply@hyperfocus.es>
